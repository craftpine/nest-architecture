// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  name         String?
  password     String
  refreshToken String?
  posts        Post[]

  @@map("users")
}

model Post {
  id           Int     @id @default(autoincrement())
  title        String
  content      String?
  published    Boolean @default(false)
  likeCount    Int     @default(0)
  dislikeCount Int     @default(0)
  author       User    @relation(fields: [authorId], references: [id])
  authorId     Int

  @@map("posts")
}

model GoldPrice {
  id           Int      @id @default(autoincrement())
  type         String   // 'vietnam' or 'world'
  goldType     String   // 'SJC', 'PNJ', 'DOJI', 'spot' etc.
  buyPrice     Float?   // Mua vào
  sellPrice    Float?   // Bán ra
  currency     String   @default("VND")
  source       String   // 'coingecko', 'sjc-scraping', 'pnj-scraping'
  sourceUrl    String?  // URL nguồn gốc
  timestamp    DateTime // Thời gian báo giá
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("gold_prices")
  @@index([type, goldType, timestamp])
  @@index([type, timestamp])
  @@index([timestamp])
  @@unique([type, goldType, source, timestamp])
}
